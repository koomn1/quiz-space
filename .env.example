# Supabase project config - from your Supabase project's Settings > API page.
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=

# Cloudflare Worker URL for AI generation endpoints (Gemini/OpenAI/Groq/DeepSeek proxy)
VITE_AI_WORKER_URL=https://quiz-space-ai.<your-subdomain>.workers.dev

# Google OAuth Client ID - for Google Drive linking feature only (separate from login).
# From: https://console.cloud.google.com/apis/credentials
VITE_GOOGLE_OAUTH_CLIENT_ID=
